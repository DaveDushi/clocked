{
  "name": "clocked-worker",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite build && vite preview",
    "deploy": "vite build && wrangler deploy",
    "test": "tsc --target es2022 --module es2022 --moduleResolution bundler --strict --skipLibCheck --types @cloudflare/workers-types --outDir .tmp-test --noEmit false src/calendar-days.ts src/dashboard.ts src/download.ts && node --test test/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "migrate:local": "wrangler d1 migrations apply clocked --local",
    "migrate:remote": "wrangler d1 migrations apply clocked --remote"
  },
  "dependencies": {
    "better-auth": "^1.6.23"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.43.0",
    "@cloudflare/workers-types": "^4.20260701.1",
    "typescript": "^5.6.0",
    "vite": "^7.3.6",
    "wrangler": "^4.107.0"
  }
}
