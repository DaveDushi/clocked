{
  "manifest_version": 3,
  "name": "clocked",
  "version": "1.0.0",
  "description": "Send the active tab's hostname to the clocked desktop app for accurate site time attribution. Local only — never uploads URLs to the cloud.",
  "homepage_url": "https://clocked.daviddusi.com",
  "permissions": ["tabs", "storage", "alarms"],
  "host_permissions": ["http://127.0.0.1/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "clocked — active site for desktop time tracking",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
