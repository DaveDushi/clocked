<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened runtime entitlements for Developer ID signing + notarization.
         clocked needs no special sandbox exceptions: it reads OS idle/session
         state, stores a token in Keychain, and makes HTTPS calls. Keep this
         minimal — add entitlements only if notarization/runtime demands them. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
